# ============================================================================
# NueOne — Root Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# These variables are used by docker-compose.yml
# ============================================================================

# ─── General ────────────────────────────────────────────────────────────────
APP_NAME=nuegrowth
APP_ENV=development
APP_DEBUG=true

# ─── Frontend ───────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Backend ────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost,http://localhost:80

# ─── Database ───────────────────────────────────────────────────────────────
DB_USER=nuegrowth
DB_PASSWORD=nuegrowth
DB_HOST=db
DB_PORT=5432
DB_NAME=nuegrowth
DATABASE_URL=postgresql+asyncpg://nuegrowth:nuegrowth@db:5432/nuegrowth

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# ─── Auth / JWT ─────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── Celery ────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── AI / LLM (Optional) ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-xxx

# ─── NextAuth (Frontend) ───────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-secure-random-string
NEXTAUTH_URL=http://localhost
