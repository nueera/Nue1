# ============================================================================
# NueOne Frontend — Environment Configuration
# ============================================================================
# Copy this file to .env.local and fill in the values
# ============================================================================

# ─── API Connection ────────────────────────────────────────────────────────
# In development (without Docker): http://localhost:8000/api/v1
# In Docker: http://backend:8000/api/v1
# Next.js rewrites will proxy /api/v1/* to this URL in dev mode
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── App URL ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── NextAuth Configuration ────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-to-a-secure-random-string
NEXTAUTH_URL=http://localhost:3000

# ─── Database (Prisma — optional, backend uses its own PostgreSQL) ──────────
DATABASE_URL="postgresql://nuegrowth:nuegrowth@localhost:5432/nueone?schema=public"

# ─── Analytics (Optional) ──────────────────────────────────────────────────
NEXT_PUBLIC_ANALYTICS_ID=""
